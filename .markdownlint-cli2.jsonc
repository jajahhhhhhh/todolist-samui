// markdownlint-cli2 configuration
{
  // Enable all rules by default
  "default": true,
  // Exclude node_modules and build output
  "ignores": [
    "node_modules",
    "dist",
    "build"
  ],
  // Example: disable line length rule
  "MD013": false,
  // Example: allow inline HTML
  "MD033": false
}
